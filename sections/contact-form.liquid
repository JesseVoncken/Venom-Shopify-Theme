{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* Keep standard padding controls + Header Clearance */
  .section-{{ section.id }}-padding {
    padding-top: calc(80px + {{ section.settings.padding_top | times: 0.75 | round: 0 }}px);
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: calc(100px + {{ section.settings.padding_top }}px);
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Custom Section Styling based on the image */
  .venom-contact-section {
    background-color: #000000;
    color: #ffffff;
    font-family: var(--font-body-family);
  }

  .venom-contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  /* --- LEFT COLUMN: INFO --- */
  .venom-contact-info .subheading {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 2px;
    color: #007bff;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: block;
  }

  .venom-contact-info .main-heading {
    font-size: 5rem; /* Large size */
    font-weight: 900;
    line-height: 1;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    font-style: italic; /* Matches the image */
  }

  .venom-contact-info .main-heading span {
    color: #007bff;
    display: block;
  }

  .venom-contact-info .description {
    font-size: 16px;
    color: #a0a0a0;
    line-height: 1.6;
    margin-bottom: 40px;
    max-width: 80%;
  }

  /* Contact Cards */
  .contact-cards-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 40px;
  }

  .contact-card {
    background-color: #0d0d0d;
    border: 1px solid #1a1a1a;
    border-radius: 8px;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
    text-decoration: none;
    color: white;
    transition: background-color 0.3s ease;
  }

  .contact-card:hover {
    background-color: #1a1a1a;
  }

  .card-icon-wrapper {
    background-color: #003366; /* Dark blue background for icon */
    color: #007bff;
    width: 40px;
    height: 40px;
    border-radius: 6px;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .card-icon-wrapper svg {
    width: 20px;
    height: 20px;
  }

  .card-content h4 {
    margin: 0;
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .card-content p {
    margin: 0;
    font-size: 12px;
    color: #888;
  }

  /* --- RIGHT COLUMN: FORM --- */
  .venom-contact-form-wrapper {
    background-color: #050505;
    border: 1px solid #111;
    border-radius: 8px;
    padding: 40px;
  }

  /* Shopify Form Overrides */
  .venom-contact-form-wrapper .field {
    margin-bottom: 25px;
    display: block;
  }

  .venom-contact-form-wrapper .field__label {
    position: static;
    display: block;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #fff;
    margin-bottom: 8px;
    pointer-events: auto;
    transform: none;
  }

  .venom-contact-form-wrapper .field__input {
    width: 100%;
    background-color: #0a0a0a;
    border: 1px solid #222;
    color: white;
    padding: 15px;
    border-radius: 4px;
    font-size: 14px;
    box-shadow: none;
  }

  .venom-contact-form-wrapper .field__input:focus {
    border-color: #007bff;
    outline: none;
    box-shadow: none;
  }

  /* Hide the default shopify floating labels */
  .venom-contact-form-wrapper .field__input::placeholder {
    color: transparent;
  }

  .venom-contact-form-wrapper .text-area {
    min-height: 150px;
    resize: vertical;
  }

  /* Send Button */
  .venom-contact-form-wrapper .button {
    width: 100%;
    background-color: #3b82f6; /* Lighter blue from image */
    color: white;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    padding: 20px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    display: block; /* ensure it's block level */
    min-height: auto;
    box-shadow: none;
  }
  
  .venom-contact-form-wrapper .button:before,
  .venom-contact-form-wrapper .button:after {
    display: none; /* Remove shopify default button effects */
  }

  .venom-contact-form-wrapper .button:hover {
    background-color: #2563eb;
  }

  /* Responsive */
  @media screen and (max-width: 900px) {
    .venom-contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .venom-contact-info .main-heading {
      font-size: 3.5rem;
    }
    .venom-contact-info .description {
      max-width: 100%;
    }
    .contact-cards-container {
      grid-template-columns: 1fr;
    }
    .venom-contact-form-wrapper {
      padding: 20px;
    }
  }
{%- endstyle -%}

<div class="venom-contact-section">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="venom-contact-grid">
      
      <div class="venom-contact-info{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        
        <span class="subheading">{{ section.settings.subheading | escape }}</span>
        
        <h2 class="main-heading">
          {{ section.settings.heading_line_1 | escape }}
          <span>{{ section.settings.heading_line_2 | escape }}</span>
        </h2>
        
        <div class="description">
          {{ section.settings.description }}
        </div>

        <div class="contact-cards-container">
          <a href="mailto:{{ section.settings.email_address }}" class="contact-card">
            <div class="card-icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="card-content">
              <h4>{{ section.settings.email_title | escape }}</h4>
              <p>{{ section.settings.email_address | escape }}</p>
            </div>
          </a>

          <a href="{{ section.settings.discord_link }}" class="contact-card" target="_blank">
            <div class="card-icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <div class="card-content">
              <h4>{{ section.settings.discord_title | escape }}</h4>
              <p>{{ section.settings.discord_text | escape }}</p>
            </div>
          </a>
        </div>
        
        <ul class="list-unstyled list-social" role="list" style="display:flex; gap: 15px; margin-top:20px;">
          {%- if settings.social_instagram_link != blank -%}
            <li>
              <a href="{{ settings.social_instagram_link }}" class="link list-social__link" style="color: #666;">
                <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-instagram" viewBox="0 0 18 18" width="24" height="24" fill="currentColor"><path fill="currentColor" d="M8.77 1.58c2.34 0 2.62.01 3.54.05.85.04 1.31.18 1.62.3.4.16.7.35 1.01.66.3.3.5.6.65 1 .12.3.26.77.3 1.62.05.92.06 1.2.06 3.54s-.01 2.62-.05 3.54c-.04.85-.18 1.31-.3 1.62-.16.4-.35.7-.66 1.01-.3.3-.6.5-1 .65-.3.12-.77.26-1.62.3-.92.05-1.2.06-3.54.06s-2.62-.01-3.54-.05c-.85-.04-1.31-.18-1.62-.3-.4-.16-.7-.35-1.01-.66-.3-.3-.5-.6-.65-1-.12-.3-.26-.77-.3-1.62-.05-.92-.06-1.2-.06-3.54s.01-2.62.05-3.54c.04-.85.18-1.31.3-1.62.16-.4.35-.7.66-1.01.3-.3.6-.5 1-.65.12-.3.77-.26 1.62-.3.92-.05 1.2-.06 3.54-.06zm0-1.58C6.39 0 6.09.01 5.15.05c-.93.04-1.57.2-2.13.42-.58.22-1.07.52-1.56 1.01C.97 1.97.67 2.46.45 3.03c-.22.56-.37 1.19-.42 2.13C-.01 6.09 0 6.39 0 8.77s.01 2.68.05 3.61c.04.94.2 1.57.42 2.13.22.58.52 1.07 1.01 1.56.49.49.98.79 1.55 1.01.56.22 1.19.37 2.13.42.94.04 1.24.05 3.62.05 2.38 0 2.68-.01 3.61-.05.94-.04 1.57-.2 2.13-.42.58-.22 1.07-.52 1.56-1.01.49-.49.79-.98 1.01-1.55.22-.56.37-1.19.42-2.13.04-.94.05-1.24.05-3.62s-.01-2.68-.05-3.61c-.04-.94-.2-1.57-.42-2.13-.22-.58-.52-1.07-1.01-1.56-.49-.49-.98-.79-1.55-1.01-.56-.22-1.19-.37-2.13-.42-.93-.04-1.23-.05-3.61-.05z"/><path fill="currentColor" d="M8.77 4.27c-2.48 0-4.5 2.02-4.5 4.5s2.02 4.5 4.5 4.5 4.5-2.02 4.5-4.5-2.02-4.5-4.5-4.5zm0 7.42c-1.61 0-2.92-1.31-2.92-2.92s1.31-2.92 2.92-2.92 2.92 1.31 2.92 2.92-1.31 2.92-2.92 2.92z"/><circle fill="currentColor" cx="13.43" cy="4.24" r="1.06"/></svg>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
             <li>
              <a href="{{ settings.social_twitter_link }}" class="link list-social__link" style="color: #666;">
                <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-twitter" viewBox="0 0 18 15" width="24" height="24" fill="currentColor"><path fill="currentColor" d="M17.64 1.74a7.33 7.33 0 01-2.08.57 3.6 3.6 0 001.58-2A7.12 7.12 0 0114.9.19 3.58 3.58 0 009.68 3c0 .28.03.56.09.83A10.18 10.18 0 011.64.67 3.56 3.56 0 002.75 5.4a3.53 3.53 0 01-1.62-.45v.05A3.6 3.6 0 004 8.52a3.55 3.55 0 01-1.61.06 3.6 3.6 0 003.36 2.5 7.2 7.2 0 01-5.32 1.5 10.15 10.15 0 005.49 1.6c6.59 0 9.19-5.46 9.19-9.19v-.46a6.56 6.56 0 001.61-1.68z"/></svg>
              </a>
            </li>
          {%- endif -%}
        </ul>

      </div>

      <div class="venom-contact-form-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        
        {%- liquid
          assign contact_form_class = 'isolate'
        -%}

        {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}
          
          {%- if form.posted_successfully? -%}
            <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus style="color:#4cd964; margin-bottom: 20px; font-size:14px;">
              {{- 'icon-success.svg' | inline_asset_content -}}
              {{ 'templates.contact.form.post_success' | t }}
            </h2>
          {%- elsif form.errors -%}
            <div class="form__message" style="color:#ff6b6b; margin-bottom: 10px;">
              <h2 class="form-status caption-large" role="alert" tabindex="-1" autofocus style="font-size:14px;">
                {{- 'icon-error.svg' | inline_asset_content -}}
                {{ 'templates.contact.form.error_heading' | t }}
              </h2>
            </div>
            <ul class="form-status-list caption-large" role="list" style="color:#ff6b6b; font-size:12px; margin-bottom: 20px;">
              <li>
                <a href="#ContactForm-email" style="color:inherit;">
                  {{ form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email }}
                </a>
              </li>
            </ul>
          {%- endif -%}

          <div class="contact__fields">
            <div class="field">
              <label class="field__label" for="ContactForm-name">YOUR NAME</label>
              <input
                class="field__input"
                autocomplete="name"
                type="text"
                id="ContactForm-name"
                name="contact[{{ 'templates.contact.form.name' | t }}]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                placeholder=""
              >
            </div>
            
            <div class="field field--with-error">
              <label class="field__label" for="ContactForm-email">YOUR EMAIL <span aria-hidden="true">*</span></label>
              <input
                autocomplete="email"
                type="email"
                id="ContactForm-email"
                class="field__input"
                name="contact[email]"
                spellcheck="false"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                aria-required="true"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="ContactForm-email-error"
                  style="border-color:#ff6b6b;"
                {% endif %}
                placeholder=""
              >
              {%- if form.errors contains 'email' -%}
                <small class="contact__field-error" id="ContactForm-email-error" style="color:#ff6b6b; display:block; margin-top:5px;">
                  <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                  <span class="form__message">
                    {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
                  </span>
                </small>
              {%- endif -%}
            </div>
          </div>

          <div class="field">
            <label class="field__label" for="ContactForm-phone">SUBJECT</label>
            <input
              type="text"
              id="ContactForm-phone"
              class="field__input"
              name="contact[Subject]"
              value=""
              placeholder=""
            >
          </div>

          <div class="field">
            <label class="form__label field__label" for="ContactForm-body">MESSAGE</label>
            <textarea
              rows="10"
              id="ContactForm-body"
              class="text-area field__input"
              name="contact[{{ 'templates.contact.form.comment' | t }}]"
              placeholder=""
            >
              {{- form.body -}}
            </textarea>
          </div>

          <div class="contact__button">
            <button type="submit" class="button">
              SEND MESSAGE
            </button>
          </div>
          
        {%- endform -%}
      </div>
      
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Venom Contact",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Left Column Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "DIRECT COMMS"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading (White)",
      "default": "CONTACT"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading (Blue)",
      "default": "THE LAB."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Have a custom request or need technical support with your order? Our tactical team is standing by.</p>"
    },
    {
      "type": "header",
      "content": "Contact Cards"
    },
    {
      "type": "text",
      "id": "email_title",
      "label": "Email Title",
      "default": "SUPPORT EMAIL"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email Address",
      "default": "comms@venomcbw.com"
    },
    {
      "type": "text",
      "id": "discord_title",
      "label": "Discord Title",
      "default": "DISCORD"
    },
    {
      "type": "text",
      "id": "discord_text",
      "label": "Discord Text",
      "default": "Join the community"
    },
    {
      "type": "url",
      "id": "discord_link",
      "label": "Discord Link"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Venom Contact"
    }
  ]
}
{% endschema %}