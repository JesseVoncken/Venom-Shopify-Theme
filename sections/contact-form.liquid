        <div class="mb-6">
          <label for="name" class="block text-sm font-bold mb-2">CALLSIGN / NAME</label>
          <input type="text" id="name" name="name" class="w-full bg-black border border-gray-800 rounded py-3 px-4 text-white focus:outline-none focus:border-blue-600" placeholder="">
